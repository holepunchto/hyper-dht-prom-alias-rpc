{
  "name": "dht-prom-alias-rpc",
  "version": "2.1.1",
  "description": "Protomux RPC for registering aliases with a dht-prometheus service",
  "main": "index.js",
  "scripts": {
    "test": "npm run format:check && lunte &&  brittle --coverage test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/dcent-tech/dht-prom-alias-rpc.git"
  },
  "keywords": [
    "DHT",
    "Prometheus",
    "protomux",
    "rpc"
  ],
  "author": "H. Degroote",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://gitlab.com/dcent-tech/dht-prom-alias-rpc/issues"
  },
  "homepage": "https://gitlab.com/dcent-tech/dht-prom-alias-rpc#readme",
  "devDependencies": {
    "brittle": "^3.6.1",
    "hypercore-crypto": "^3.4.2",
    "hyperdht": "^6.16.0",
    "hyperswarm": "^4.8.1",
    "lunte": "^1.8.0",
    "newline-decoder": "^1.0.2",
    "prettier": "^3.8.3",
    "prettier-config-holepunch": "^2.0.0"
  },
  "dependencies": {
    "b4a": "^1.6.6",
    "bare-crypto": "^1.11.2",
    "bare-events": "^2.6.1",
    "compact-encoding": "^3.0.0",
    "hypercore-id-encoding": "^1.3.0",
    "protomux-rpc": "^1.7.0",
    "protomux-rpc-client": "^2.0.1",
    "safety-catch": "^1.0.2"
  },
  "files": [
    "index.js",
    "client.js",
    "lib/**.js"
  ],
  "imports": {
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "events": {
      "bare": "bare-events",
      "default": "events"
    }
  }
}
